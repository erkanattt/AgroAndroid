        <item name="android:windowLightStatusBar">false</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/surface_elevated</item>
        <item name="colorOutline">@color/card_stroke</item>
    </style>
    <style name="Widget.Agro.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/card</item>
        <item name="cardCornerRadius">20dp</item>
