<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <include
        android:id="@+id/panelLocked"
        layout="@layout/panel_ai_locked"
        android:visibility="gone"
        tools:visibility="gone" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/panelDiagnose"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/identify_title"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/identify_subtitle"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:layout_marginTop="16dp">

                <ImageView
                    android:id="@+id/imagePreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/surface_elevated"
                    android:contentDescription="@null"
                    android:scaleType="centerCrop"
                    tools:src="@drawable/bg_leaf_preview" />

                <View
                    android:id="@+id/overlayScanFrame"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="24dp"
                    android:background="@drawable/bg_scan_frame" />

                <TextView
                    android:id="@+id/overlayEmptyHint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="@string/ai_tap_to_pick"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

                <FrameLayout
                    android:id="@+id/overlayAnalyzing"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#99000000"
                    android:visibility="gone">

                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:indeterminate="true"
                        app:indicatorColor="@color/accent" />
                </FrameLayout>
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGallery"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:text="@string/pick_gallery"
                    android:textAllCaps="false"
                    android:textColor="@color/accent"
                    app:cornerRadius="24dp"
                    app:strokeColor="@color/accent" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCamera"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/take_photo"
                    android:textAllCaps="false"
                    android:textColor="@color/accent"
                    app:cornerRadius="24dp"
                    app:strokeColor="@color/accent" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAnalyze"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:enabled="false"
                android:text="@string/analyze"
                android:textAllCaps="false"
                android:textColor="@color/background"
                app:backgroundTint="@color/accent"
                app:cornerRadius="26dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/surface_elevated"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp"
                tools:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/diagnosis_result_title"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/textDiseaseName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="@color/accent"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        tools:text="Фитофтороз" />

                    <TextView
                        android:id="@+id/textResultBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:textSize="12sp"
                        tools:text="Ауру" />

                    <TextView
                        android:id="@+id/textConfidence"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        tools:text="Сенімділік: 92%" />

                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progressConfidence"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        app:indicatorColor="@color/accent"
                        app:trackColor="@color/card_stroke" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="@string/about_disease"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/textSymptoms"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:lineSpacingExtra="3dp"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/diagnosis_prevention"
                        android:textColor="@color/accent"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/textPrevention"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:lineSpacingExtra="3dp"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSave"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="16dp"
                        android:text="@string/action_save"
                        android:textAllCaps="false"
                        android:textColor="@color/background"
                        app:backgroundTint="@color/accent"
                        app:cornerRadius="24dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</FrameLayout>
