<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_main"
    app:startDestination="@id/nav_home">

    <fragment
        android:id="@+id/nav_home"
        android:name="kz.agrosfera.app.ui.home.HomeFragment"
        android:label="@string/nav_home"
        tools:layout="@layout/fragment_home" />

    <fragment
        android:id="@+id/nav_check"
        android:name="kz.agrosfera.app.ui.diagnose.DiagnoseFragment"
        android:label="@string/nav_identify"
        tools:layout="@layout/fragment_diagnose">
        <action
            android:id="@+id/action_diagnose_to_treatment"
            app:destination="@id/treatmentFragment" />
        <action
            android:id="@+id/action_diagnose_to_login"
            app:destination="@id/loginFragment" />
        <action
            android:id="@+id/action_diagnose_to_register"
            app:destination="@id/registerFragment" />
    </fragment>

    <fragment
        android:id="@+id/nav_field"
        android:name="kz.agrosfera.app.ui.plants.PlantsFragment"
        android:label="@string/nav_plants"
        tools:layout="@layout/fragment_plants" />

    <fragment
        android:id="@+id/nav_knowledge"
        android:name="kz.agrosfera.app.ui.diseases.CategoriesFragment"
        android:label="@string/nav_categories"
        tools:layout="@layout/fragment_categories">
        <action
            android:id="@+id/action_categories_to_disease_list"
            app:destination="@id/categoryDiseasesFragment" />
    </fragment>

    <fragment
        android:id="@+id/categoryDiseasesFragment"
        android:name="kz.agrosfera.app.ui.diseases.CategoryDiseasesFragment"
        android:label="@string/category_diseases_title"
        tools:layout="@layout/fragment_category_diseases">
        <argument
            android:name="categoryId"
            app:argType="string" />
        <action
            android:id="@+id/action_disease_list_to_detail"
            app:destination="@id/diseaseDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/diseaseDetailFragment"
        android:name="kz.agrosfera.app.ui.diseases.DiseaseDetailFragment"
        android:label="@string/disease_detail_title"
        tools:layout="@layout/fragment_disease_detail">
        <argument
            android:name="diseaseId"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/nav_profile"
        android:name="kz.agrosfera.app.ui.profile.ProfileFragment"
        android:label="@string/nav_profile"
        tools:layout="@layout/fragment_profile">
        <action
            android:id="@+id/action_profile_to_login"
            app:destination="@id/loginFragment" />
        <action
            android:id="@+id/action_profile_to_register"
            app:destination="@id/registerFragment" />
    </fragment>

    <fragment
        android:id="@+id/treatmentFragment"
        android:name="kz.agrosfera.app.ui.treatment.TreatmentFragment"
        android:label="@string/treatment_title"
        tools:layout="@layout/fragment_treatment" />

    <fragment
        android:id="@+id/loginFragment"
        android:name="kz.agrosfera.app.ui.auth.LoginFragment"
        android:label="@string/login_title"
        tools:layout="@layout/fragment_login">
        <argument
            android:name="redirect_ai"
            android:defaultValue="false"
            app:argType="boolean" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="kz.agrosfera.app.ui.auth.RegisterFragment"
        android:label="@string/register_title"
        tools:layout="@layout/fragment_register">
        <argument
            android:name="redirect_ai"
            android:defaultValue="false"
            app:argType="boolean" />
    </fragment>
</navigation>
